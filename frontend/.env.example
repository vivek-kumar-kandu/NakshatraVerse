VITE_API_BASE_URL=http://localhost:8617

# Priority 5.2: optional — enables the "Sign in with Google" button on the
# Login/Signup pages. Must match the backend's GOOGLE_CLIENT_ID (same
# OAuth 2.0 Client ID from https://console.cloud.google.com/apis/credentials).
# Leave blank to disable Google sign-in (email/password still works).
VITE_GOOGLE_CLIENT_ID=
