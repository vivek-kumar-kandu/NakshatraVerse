# Copy this file to .env and fill in real values. Never commit .env itself
# (see .gitignore) — it holds your real Gemini API key.

# ── Required ────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here   # alternate name, also accepted

# ── Server ──────────────────────────────────────────────────────────────
PORT=8617
NODE_ENV=development
# Comma-separated list of allowed origins, or "*" for any (dev default).
FRONTEND_ORIGIN=http://localhost:5187

# ── Gemini model / resilience ───────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=25000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_MS=1000
GEMINI_TOTAL_BUDGET_MS=45000

# ── Priority 4: Performance & Production Hardening (all optional) ──────
# "text" (default) or "json" structured logs.
LOG_FORMAT=text

# Astrology chart cache (deterministic per name/dob/tob/pob).
CHART_CACHE_TTL_MS=21600000
CHART_CACHE_MAX_ENTRIES=500

# Gemini narrative cache (keyed on the exact prompt sent, which changes
# daily due to transit data — see transitEngine.js).
GEMINI_CACHE_TTL_MS=3600000
GEMINI_CACHE_MAX_ENTRIES=200

# Basic per-IP rate limiting on the two POST endpoints.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_CHART=60
RATE_LIMIT_MAX_REPORT=20
# V4.0 Phase 1 (Kundli Matching) — computes two full charts per request.
RATE_LIMIT_MAX_MATCHING=15

# Max JSON request body size (birth-data payloads are tiny; this just caps abuse).
MAX_REQUEST_BODY_SIZE=100kb

# ── Priority 5.2: Auth, User Management, Saved Reports, PDF Export ─────
# Secret used to sign session JWTs. REQUIRED in production — the server
# refuses to start without one. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Access token lifetime (short-lived; refreshed automatically via
# POST /api/auth/refresh) and refresh token lifetime (long-lived).
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_MAX_AGE_MS=2592000000

# Optional: enables "Sign in with Google". Create an OAuth 2.0 Client ID at
# https://console.cloud.google.com/apis/credentials and set both this and
# the matching VITE_GOOGLE_CLIENT_ID in frontend/.env. Leave blank to
# disable Google sign-in (email/password auth still works).
GOOGLE_CLIENT_ID=

# Where the file-backed users/reports store lives. Point this at a
# persistent volume/disk in production (see DEPLOYMENT.md).
DATA_DIR=./data

# Cookies are HTTPS-only (Secure) by default in production. Override only
# if you understand the security tradeoff (e.g. local HTTP testing of a
# production build).
COOKIE_SECURE=

# bcrypt cost factor for password hashing.
BCRYPT_SALT_ROUNDS=12

# Per-IP rate limit on auth endpoints (register/login/google/refresh).
RATE_LIMIT_MAX_AUTH=30

# ── V3.0 Phase 4: AI Astrology Assistant (chat) ─────────────────────────
RATE_LIMIT_MAX_ASSISTANT=40
# Max turns of chat history sent back to Gemini as context per request.
ASSISTANT_MAX_HISTORY_TURNS=10
# Max characters accepted in a single chat question.
ASSISTANT_MAX_QUESTION_LENGTH=600

# ── V4.1 Phase 2: Daily Panchang & Muhurat Finder ───────────────────────
RATE_LIMIT_MAX_PANCHANG=40

# ── V4.2: Family Profiles & Relationship Hub ────────────────────────────
RATE_LIMIT_MAX_FAMILY_PROFILES=60
RATE_LIMIT_MAX_RELATIONSHIP_HUB=15

# ── V4.3: AI Life Coach ──────────────────────────────────────────────────
RATE_LIMIT_MAX_LIFE_COACH=40

# ── V4.4 Phase 1: Notification Infrastructure ───────────────────────────
RATE_LIMIT_MAX_NOTIFICATIONS=60

# ── V4.5: Festival Backend Infrastructure & Festival Intelligence ───────
RATE_LIMIT_MAX_FESTIVALS=40
RATE_LIMIT_MAX_FESTIVAL_INTELLIGENCE=30

# ── V5.0 Phase 5C: Explorer AI ───────────────────────────────────────────
RATE_LIMIT_MAX_EXPLORER_AI=40
# Max characters accepted in an Explorer AI explanation label field.
EXPLORER_AI_MAX_LABEL_LENGTH=120

# ── V5.2: AI Timeline ─────────────────────────────────────────────────────
RATE_LIMIT_MAX_AI_TIMELINE=40
AI_TIMELINE_MAX_LABEL_LENGTH=120

# ── V5.3: Explainable Report Intelligence ────────────────────────────────
RATE_LIMIT_MAX_EXPLANATION=60
EXPLANATION_MAX_LABEL_LENGTH=120
# Cache for generated explanations (1h default).
EXPLANATION_CACHE_TTL_MS=3600000
EXPLANATION_CACHE_MAX_ENTRIES=300
