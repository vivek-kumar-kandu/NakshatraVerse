# ─────────────────────────────────────────────────────────────────────────
# NakshatraVerse — root .gitignore (covers backend/ and frontend/)
# ─────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
dist/
build/
frontend/dist/
frontend/build/

# Test coverage
coverage/
backend/coverage/
frontend/coverage/

# Environment files — never commit real secrets.
# .env.example is explicitly re-included below so it still gets tracked.
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Runtime data — the file-backed JsonFileStore. Contains real user records
# (emails, password hashes, saved reports) once the app has been run.
# Must never be committed; production data lives on a persistent volume,
# not in git history.
backend/data/
data/

# Logs
*.log
npm-debug.log*
logs/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Misc caches
.cache/
.temp/
tmp/

# Optional package manager logs
pnpm-debug.log*
yarn-error.log*
yarn-debug.log*

# Optional dotenv local overrides
*.local

# Optional archive files
*.zip
*.tar
*.gz

audit-report.json